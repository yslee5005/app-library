# Single source of truth for shared keys across all apps.
# Copy to .env and fill in values (file is gitignored).
#
# scripts/prepare_env.sh reads this + apps/<app>/.env.client
# and writes apps/<app>/.env.runtime for Flutter to load at launch.
# Keys under "Server-only" are automatically excluded from that runtime
# file so they never ship in the client bundle.

# --- Shared client keys (bundled into every app) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
GEMINI_API_KEY=your-gemini-key
SENTRY_DSN=

# --- Server-only (NEVER bundled — used by Supabase CLI, Edge Functions, scripts/*.sh) ---
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
