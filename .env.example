# Single source of truth for shared keys across all apps.
# Copy to .env and fill in values (file is gitignored).
#
# scripts/prepare_env.sh reads this + apps/<app>/.env.client and writes
# apps/<app>/.env.runtime for Flutter to load at launch. Keys under
# "Server-only" are automatically excluded from that runtime file so they
# never ship in the client bundle.

# --- Shared client keys (bundled into every app) ---

# Supabase Dashboard > Project Settings > API > Project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase Dashboard > Project Settings > API > anon / public key
SUPABASE_ANON_KEY=your-anon-key

# Google AI Studio > https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key

# Sentry.io > Project Settings > Client Keys (DSN) — leave empty to disable
SENTRY_DSN=

# --- Server-only (NEVER bundled — CLI / Edge Functions / scripts/*.sh) ---

# Supabase Dashboard > Project Settings > API > service_role key
# ⚠️ god-mode DB access. Never paste into apps/<app>/.env.client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
