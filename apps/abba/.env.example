# Abba App Environment Variables
# Copy to .env.client and fill in real values
# Loaded at runtime via flutter_dotenv (NOT --dart-define)
#
# For mock mode (Phase 1 demo): set ENV=mock
# For real mode (Phase 2+):     set ENV=real

ENV=mock
APP_ID=abba
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
OPENAI_API_KEY=sk-your-key
SENTRY_DSN=https://your-dsn@sentry.io/your-project
REVENUECAT_API_KEY=your-revenuecat-key
