# Abba — app-specific env keys. Shared keys (SUPABASE_URL, GEMINI_API_KEY,
# SENTRY_DSN) live in the root .env. scripts/prepare_env.sh merges both
# into apps/abba/.env.runtime at build time.
#
# Copy to .env.client and fill in values (file is gitignored).

ENV=dev
APP_ID=abba

# AI toggle: 'true' → use hardcoded mock responses (no Gemini cost, offline dev)
#            'false' → call real Gemini API (production, App Store review)
# Default: true in dev, false in production builds.
ENABLE_MOCK_AI=true

# Google Cloud Console > APIs & Services > Credentials
# GOOGLE_WEB_CLIENT_ID is shared across all apps on the same Supabase project.
GOOGLE_WEB_CLIENT_ID=shared-web-client-id
# GOOGLE_IOS_CLIENT_ID is per-app, per-platform — bound to the iOS bundle id.
GOOGLE_IOS_CLIENT_ID=per-app-ios-client-id

# RevenueCat Dashboard > Project > API Keys — one per platform.
# iOS key starts with "appl_", Android starts with "goog_".
REVENUECAT_IOS_KEY=appl_your-ios-public-sdk-key
REVENUECAT_ANDROID_KEY=goog_your-android-public-sdk-key

# ──────────────────────────────────────────
# Public URLs (GitHub Pages default, override with custom domain)
# ──────────────────────────────────────────
# AppConfig falls back to https://yslee5005.github.io/abba-docs/{help,terms,privacy}
# when these are unset. Uncomment + fill to switch to a custom domain once
# the DNS is live. Apple Guideline 3.1.2 requires Terms/Privacy links under
# the purchase button — both URLs must resolve before submission.
# HELP_URL=https://abba.ystech.app/help
# TERMS_URL=https://abba.ystech.app/terms
# PRIVACY_URL=https://abba.ystech.app/privacy
