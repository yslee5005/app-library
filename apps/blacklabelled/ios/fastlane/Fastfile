default_platform(:ios)

# Absolute path to app root
APP_ROOT = File.expand_path('../..', __dir__)

# App Store Connect API Key
API_KEY = app_store_connect_api_key(
  key_id: "92BADV9F52",
  issuer_id: "44f25ef3-5982-4b3b-b575-864a88de8c72",
  key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_92BADV9F52.p8"),
)

TEAM_ID = "287896ZJHM"
APP_IDENTIFIER = "com.ystech.blacklabelled"
APP_NAME = "Blacklabelled"

# JWT 생성 + Apple REST API로 Bundle ID 등록하는 스크립트
def register_bundle_id_via_api(app_identifier, app_name, team_id)
  require 'jwt'
  require 'net/http'
  require 'json'
  require 'uri'

  key_id = "92BADV9F52"
  issuer_id = "44f25ef3-5982-4b3b-b575-864a88de8c72"
  key_path = File.expand_path("~/.appstoreconnect/private_keys/AuthKey_92BADV9F52.p8")

  # JWT 생성
  private_key = OpenSSL::PKey::EC.new(File.read(key_path))
  payload = {
    iss: issuer_id,
    iat: Time.now.to_i,
    exp: Time.now.to_i + 1200,
    aud: "appstoreconnect-v1",
  }
  token = JWT.encode(payload, private_key, "ES256", { kid: key_id, typ: "JWT" })

  headers = {
    "Authorization" => "Bearer #{token}",
    "Content-Type" => "application/json",
  }

  # 1. Bundle ID가 이미 있는지 확인
  uri = URI("https://api.appstoreconnect.apple.com/v1/bundleIds?filter[identifier]=#{app_identifier}")
  http = Net::HTTP.new(uri.host, uri.port)
  http.use_ssl = true
  req = Net::HTTP::Get.new(uri, headers)
  res = http.request(req)
  data = JSON.parse(res.body)

  if data["data"] && data["data"].length > 0
    Fastlane::UI.important("ℹ️  Bundle ID '#{app_identifier}' already exists.")
    return true
  end

  # 2. Bundle ID 등록
  uri = URI("https://api.appstoreconnect.apple.com/v1/bundleIds")
  http = Net::HTTP.new(uri.host, uri.port)
  http.use_ssl = true
  req = Net::HTTP::Post.new(uri, headers)
  req.body = {
    data: {
      type: "bundleIds",
      attributes: {
        name: app_name,
        identifier: app_identifier,
        platform: "IOS",
      },
    },
  }.to_json

  res = http.request(req)
  if res.code.to_i >= 200 && res.code.to_i < 300
    Fastlane::UI.success("✅ Bundle ID '#{app_identifier}' registered!")
    return true
  else
    error_body = JSON.parse(res.body) rescue res.body
    Fastlane::UI.error("❌ Bundle ID registration failed: #{error_body}")
    return false
  end
end

def register_app_via_api(app_identifier, app_name)
  require 'jwt'
  require 'net/http'
  require 'json'
  require 'uri'

  key_id = "92BADV9F52"
  issuer_id = "44f25ef3-5982-4b3b-b575-864a88de8c72"
  key_path = File.expand_path("~/.appstoreconnect/private_keys/AuthKey_92BADV9F52.p8")

  private_key = OpenSSL::PKey::EC.new(File.read(key_path))
  payload = {
    iss: issuer_id,
    iat: Time.now.to_i,
    exp: Time.now.to_i + 1200,
    aud: "appstoreconnect-v1",
  }
  token = JWT.encode(payload, private_key, "ES256", { kid: key_id, typ: "JWT" })

  headers = {
    "Authorization" => "Bearer #{token}",
    "Content-Type" => "application/json",
  }

  # 앱이 이미 있는지 확인
  uri = URI("https://api.appstoreconnect.apple.com/v1/apps?filter[bundleId]=#{app_identifier}")
  http = Net::HTTP.new(uri.host, uri.port)
  http.use_ssl = true
  req = Net::HTTP::Get.new(uri, headers)
  res = http.request(req)
  data = JSON.parse(res.body)

  if data["data"] && data["data"].length > 0
    Fastlane::UI.important("ℹ️  App '#{app_identifier}' already exists on App Store Connect.")
    return true
  end

  # Bundle ID의 ID 조회 (앱 생성에 필요)
  uri = URI("https://api.appstoreconnect.apple.com/v1/bundleIds?filter[identifier]=#{app_identifier}")
  http = Net::HTTP.new(uri.host, uri.port)
  http.use_ssl = true
  req = Net::HTTP::Get.new(uri, headers)
  res = http.request(req)
  bundle_data = JSON.parse(res.body)
  bundle_id_resource_id = bundle_data["data"]&.first&.dig("id")

  unless bundle_id_resource_id
    Fastlane::UI.error("❌ Bundle ID not found, cannot create app.")
    return false
  end

  # Apple 정책상 App Store Connect 앱 생성은 자동화가 불안정/제한될 수 있으므로
  # Fastlane에서는 생성 API를 호출하지 않고 수동 생성만 안내한다.
  Fastlane::UI.important("ℹ️  Automatic App Store Connect app creation is disabled by policy.")
  Fastlane::UI.important("ℹ️  Please create app manually once: #{app_name} (#{app_identifier})")
  return true
end

platform :ios do

  desc "Full pipeline: register → sign → build → TestFlight"
  lane :deploy do

    # 0. 키체인 잠금 해제
    keychain_password = ENV["KEYCHAIN_PASSWORD"]
    if keychain_password && !keychain_password.empty?
      sh("security unlock-keychain -p '#{keychain_password}' ~/Library/Keychains/login.keychain-db")
      UI.success("✅ Keychain unlocked!")
    end

    # 1. Bundle ID 등록 (Apple REST API 직접 호출)
    register_bundle_id_via_api(APP_IDENTIFIER, APP_NAME, TEAM_ID)

    # 2. App Store Connect 앱 등록
    register_app_via_api(APP_IDENTIFIER, APP_NAME)

    # 3. Distribution 인증서
    cert(
      api_key: API_KEY,
      team_id: TEAM_ID,
    )
    UI.success("✅ Distribution certificate ready!")

    # 4. Provisioning Profile
    sigh(
      api_key: API_KEY,
      app_identifier: APP_IDENTIFIER,
      team_id: TEAM_ID,
    )
    UI.success("✅ Provisioning profile ready!")

    # 5. 빌드 번호 자동 증가
    latest = latest_testflight_build_number(
      api_key: API_KEY,
      app_identifier: APP_IDENTIFIER,
    )
    new_build_number = latest + 1
    UI.success("✅ Build number: #{new_build_number}")

    # 6. Flutter IPA 빌드
    sh("cd '#{APP_ROOT}' && flutter build ipa --release --obfuscate --split-debug-info=build/debug-info --export-options-plist=ios/ExportOptions.plist --build-number=#{new_build_number}")
    UI.success("✅ Build complete!")

    # 6. TestFlight 업로드
    ipa_path = Dir.glob("#{APP_ROOT}/build/ios/ipa/*.ipa").first
    if ipa_path.nil?
      UI.user_error!("❌ IPA file not found in #{APP_ROOT}/build/ios/ipa/")
    end

    upload_to_testflight(
      api_key: API_KEY,
      ipa: ipa_path,
      skip_waiting_for_build_processing: false,
      uses_non_exempt_encryption: false,
    )
    UI.success("✅ Uploaded to TestFlight!")
  end

end
